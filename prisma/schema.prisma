generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrganizationStatus {
  active
  suspended
  archived
}

enum UserStatus {
  active
  blocked
  invited
}

enum MembershipRole {
  employee
  manager
  admin
}

enum SessionMode {
  talk
  exam_prep
  chat_test
}

enum Difficulty {
  basic
  medium
  hard
}

enum WorkStatus {
  draft
  active
  completed
  failed
}

enum ExamStatus {
  active
  passed
  failed
  review
}

enum NotificationType {
  training
  exam
  recommendation
  system
}

enum AuthProvider {
  password
  google
  yandex
}

enum QuestionType {
  single_choice
  multiple_choice
  true_false
  matching
  text_input
  number_input
}

enum AnswerFormat {
  choice
  text_manual
}

enum TargetRole {
  manager
  lawyer
  both
}

model Organization {
  id               String            @id @default(uuid()) @db.Uuid
  name             String
  slug             String            @unique
  status           OrganizationStatus @default(active)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  memberships      Membership[]
  consents         Consent[]
  trainingTopics   TrainingTopic[]
  trainingSessions TrainingSession[]
  trainingMessages TrainingMessage[]
  examAttempts     ExamAttempt[]
  weakTopics       WeakTopic[]
  notifications    Notification[]
  clientLeads      ClientLead[]
  auditLogs        AuditLog[]
  systemSettings   SystemSetting[]
  testQuestions    TestQuestion[]
  caseTemplates    CaseTemplate[]
  objectionTemplates ObjectionTemplate[]
  callScripts      CallScript[]
  trainingPrograms TrainingProgram[]

  @@map("organizations")
}

model User {
  id               String            @id @default(uuid()) @db.Uuid
  email            String            @unique
  fullName         String            @map("full_name")
  avatarUrl        String?           @map("avatar_url")
  status           UserStatus        @default(active)
  lastLoginAt      DateTime?         @map("last_login_at")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  memberships      Membership[]
  authAccounts     AuthAccount[]
  passwordResetTokens PasswordResetToken[]
  sessions         Session[]
  consents         Consent[]
  trainingSessions TrainingSession[]
  examAttempts     ExamAttempt[]
  weakTopics       WeakTopic[]
  notifications    Notification[]
  auditLogs        AuditLog[]

  @@map("users")
}

model Membership {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @map("organization_id") @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  role           MembershipRole
  status         UserStatus     @default(active)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId], map: "memberships_org_user_unique")
  @@index([organizationId], map: "memberships_organization_id_idx")
  @@index([userId], map: "memberships_user_id_idx")
  @@map("memberships")
}

model AuthAccount {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  provider       AuthProvider
  providerUserId String       @map("provider_user_id")
  passwordHash   String?      @map("password_hash")
  failedLoginAttempts Int     @default(0) @map("failed_login_attempts")
  lockedUntil    DateTime?    @map("locked_until")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId], map: "auth_accounts_provider_user_unique")
  @@index([userId], map: "auth_accounts_user_id_idx")
  @@map("auth_accounts")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "password_reset_tokens_user_id_idx")
  @@index([expiresAt], map: "password_reset_tokens_expires_at_idx")
  @@map("password_reset_tokens")
}

model Session {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([expiresAt], map: "sessions_expires_at_idx")
  @@map("sessions")
}

model Consent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  version        String
  acceptedAt     DateTime     @map("accepted_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "consents_organization_id_idx")
  @@index([userId], map: "consents_user_id_idx")
  @@map("consents")
}

model TrainingTopic {
  id               String            @id @default(uuid()) @db.Uuid
  organizationId   String            @map("organization_id") @db.Uuid
  title            String
  description      String?
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainingSessions TrainingSession[]
  examAttempts     ExamAttempt[]
  weakTopics       WeakTopic[]

  @@index([organizationId], map: "training_topics_organization_id_idx")
  @@map("training_topics")
}

model TrainingSession {
  id             String            @id @default(uuid()) @db.Uuid
  organizationId String            @map("organization_id") @db.Uuid
  userId         String            @map("user_id") @db.Uuid
  topicId        String            @map("topic_id") @db.Uuid
  mode           SessionMode
  difficulty     Difficulty
  format         String            @default("text")
  character      String            @default("anxious")
  questionCount  Int               @default(20) @map("question_count")
  score          Int?
  evaluationCriteria Json?         @map("evaluation_criteria")
  mistakes       Json?
  recommendations Json?
  status         WorkStatus        @default(draft)
  startedAt      DateTime          @map("started_at")
  completedAt    DateTime?         @map("completed_at")

  organization   Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          TrainingTopic     @relation(fields: [topicId], references: [id], onDelete: Restrict)
  messages       TrainingMessage[]

  @@index([organizationId], map: "training_sessions_organization_id_idx")
  @@index([userId], map: "training_sessions_user_id_idx")
  @@index([topicId], map: "training_sessions_topic_id_idx")
  @@map("training_sessions")
}

model TrainingMessage {
  id                String          @id @default(uuid()) @db.Uuid
  organizationId    String          @map("organization_id") @db.Uuid
  trainingSessionId String          @map("training_session_id") @db.Uuid
  sender            String
  content           String
  createdAt         DateTime        @default(now()) @map("created_at")

  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  trainingSession   TrainingSession @relation(fields: [trainingSessionId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "training_messages_organization_id_idx")
  @@index([trainingSessionId], map: "training_messages_session_id_idx")
  @@map("training_messages")
}

model ExamAttempt {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  topicId        String        @map("topic_id") @db.Uuid
  score          Int?
  passingScore   Int           @map("passing_score")
  status         ExamStatus    @default(active)
  startedAt      DateTime      @map("started_at")
  completedAt    DateTime?     @map("completed_at")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          TrainingTopic @relation(fields: [topicId], references: [id], onDelete: Restrict)

  @@index([organizationId], map: "exam_attempts_organization_id_idx")
  @@index([userId], map: "exam_attempts_user_id_idx")
  @@index([topicId], map: "exam_attempts_topic_id_idx")
  @@map("exam_attempts")
}

model WeakTopic {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String        @map("organization_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  topicId        String        @map("topic_id") @db.Uuid
  errorsCount    Int           @map("errors_count")
  recommendation String
  updatedAt      DateTime      @updatedAt @map("updated_at")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic          TrainingTopic @relation(fields: [topicId], references: [id], onDelete: Restrict)

  @@index([organizationId], map: "weak_topics_organization_id_idx")
  @@index([userId], map: "weak_topics_user_id_idx")
  @@index([topicId], map: "weak_topics_topic_id_idx")
  @@map("weak_topics")
}

model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  organizationId String           @map("organization_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  type           NotificationType
  title          String
  body           String
  readAt         DateTime?        @map("read_at")
  createdAt      DateTime         @default(now()) @map("created_at")

  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "notifications_organization_id_idx")
  @@index([userId], map: "notifications_user_id_idx")
  @@index([readAt], map: "notifications_read_at_idx")
  @@map("notifications")
}

model ClientLead {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String?       @map("organization_id") @db.Uuid
  name           String
  phone          String?
  email          String?
  question       String
  status         String        @default("new")
  createdAt      DateTime      @default(now()) @map("created_at")

  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "client_leads_organization_id_idx")
  @@index([status], map: "client_leads_status_idx")
  @@map("client_leads")
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  actorUserId    String?      @map("actor_user_id") @db.Uuid
  action         String
  targetType     String       @map("target_type")
  targetId       String?      @map("target_id") @db.Uuid
  metadata       Json
  createdAt      DateTime     @default(now()) @map("created_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actor          User?        @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organizationId], map: "audit_logs_organization_id_idx")
  @@index([actorUserId], map: "audit_logs_actor_user_id_idx")
  @@index([action], map: "audit_logs_action_idx")
  @@map("audit_logs")
}

model SystemSetting {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @map("organization_id") @db.Uuid
  key            String
  value          Json
  updatedAt      DateTime     @updatedAt @map("updated_at")

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key], map: "system_settings_org_key_unique")
  @@index([organizationId], map: "system_settings_organization_id_idx")
  @@map("system_settings")
}

model TestQuestion {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  title           String
  text            String
  type            QuestionType
  attachmentUrl   String?      @map("attachment_url")
  
  options         Json?
  correctAnswer   Json         @map("correct_answer")
  explanation     String?
  
  difficulty      Difficulty   @default(medium)
  tags            String[]
  needsUpdate     Boolean      @default(false) @map("needs_update")
  
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "test_questions_organization_id_idx")
  @@map("test_questions")
}

model CaseTemplate {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  title           String
  introText       String       @map("intro_text")
  attachments     String[]

  difficulty      Difficulty   @default(medium)
  tags            String[]
  
  steps           CaseStep[]

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "case_templates_organization_id_idx")
  @@map("case_templates")
}

model CaseStep {
  id              String       @id @default(uuid()) @db.Uuid
  caseId          String       @map("case_id") @db.Uuid
  question        String
  answerFormat    AnswerFormat @map("answer_format")
  
  options         Json?
  correctOptionId String?      @map("correct_option_id")
  
  keywordRules    Json?        @map("keyword_rules")
  referenceAnswer String?      @map("reference_answer")

  isRedFlag       Boolean      @default(false) @map("is_red_flag")

  case            CaseTemplate @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId], map: "case_steps_case_id_idx")
  @@map("case_steps")
}

model ObjectionTemplate {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  category        String
  clientPhrase    String       @map("client_phrase")
  
  targetRole      TargetRole   @map("target_role")
  answerFormat    AnswerFormat @map("answer_format")

  options         Json?
  correctOptionId String?      @map("correct_option_id")
  
  keywordRules    Json?        @map("keyword_rules")
  referenceAnswer String       @map("reference_answer")
  explanation     String?

  difficulty      Difficulty   @default(medium)

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "objection_templates_organization_id_idx")
  @@map("objection_templates")
}

model CallScript {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  title           String
  clientProfile   Json         @map("client_profile")
  
  firstNodeId     String?      @map("first_node_id")
  nodes           CallScriptNode[]

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "call_scripts_organization_id_idx")
  @@map("call_scripts")
}

model CallScriptNode {
  id              String       @id @default(uuid()) @db.Uuid
  scriptId        String       @map("script_id") @db.Uuid
  clientReplica   String       @map("client_replica")
  
  answerFormat    AnswerFormat @map("answer_format")
  
  options         Json?
  keywordRules    Json?        @map("keyword_rules")
  
  isSuccessEnd    Boolean      @default(false) @map("is_success_end")
  isFailEnd       Boolean      @default(false) @map("is_fail_end")

  script          CallScript   @relation(fields: [scriptId], references: [id], onDelete: Cascade)

  @@index([scriptId], map: "call_script_nodes_script_id_idx")
  @@map("call_script_nodes")
}

model TrainingProgram {
  id              String       @id @default(uuid()) @db.Uuid
  organizationId  String       @map("organization_id") @db.Uuid
  title           String
  description     String?

  items           Json

  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId], map: "training_programs_organization_id_idx")
  @@map("training_programs")
}

