# Copy to deployment/prod.env on the server (chmod 600, NEVER commit).
# Generate secrets: openssl rand -hex 32 / -hex 24
DOMAIN=legalhunter.pro
PUBLIC_URL=https://legalhunter.pro
PUBLIC_WS_URL=wss://legalhunter.pro
POSTGRES_DB=legalhunter
POSTGRES_USER=legalhunter
POSTGRES_PASSWORD=__gen_openssl_rand_hex_24__
REDIS_PASSWORD=__gen_openssl_rand_hex_24__
JWT_SECRET=__gen_openssl_rand_hex_32__
CSRF_SECRET=__gen_openssl_rand_hex_32__
# navy.api drives LLM+STT+TTS (the field set that actually enables AI)
NAVY_API_KEY=sk-navy-__your_key__
NAVY_BASE_URL=https://api.navy/v1
NAVY_LLM_MODEL=deepseek-v4-pro
WHISPER_URL=https://api.navy
WEB_LLM_MODEL=deepseek-v4-pro
# Telegram bot (@BFLHUNTER_bot). Bot runs in POLLING mode (bot service) because
# the RU host can't receive webhooks; egress via the api.telegram.org IP pin.
TELEGRAM_BOT_TOKEN=__bot_token_from_BotFather__
TELEGRAM_BOT_USERNAME=BFLHUNTER_bot
TELEGRAM_WEBHOOK_SECRET=__gen_openssl_rand_hex_32__
TELEGRAM_PROXY=
# Optional integrations (empty = dark)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://legalhunter.pro/auth/callback
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=
YANDEX_REDIRECT_URI=https://legalhunter.pro/auth/callback
